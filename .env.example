# API anahtarlarınızı buraya değil, .env dosyasına ekleyin.
# Bu dosya (.env.example) sadece hangi değişkenlerin gerektiğini gösterir; GitHub'a yüklenmesi güvenlidir.

# AI sağlayıcısı: gemini veya claude
AI_PROVIDER=gemini

# Gemini kullanacaksanız Google AI Studio key'i
GEMINI_API_KEY=senin_google_ai_studio_keyin

# Claude kullanacaksanız Anthropic key'i
ANTHROPIC_API_KEY=senin_anthropic_keyin

# Flask ayarları
FLASK_SECRET_KEY=degistir-bu-anahtari
FLASK_DEBUG=True
ADMIN_PASSWORD=degistir-bu-admin-sifresini

# İleride veritabanı eklenirse (örn. kullanıcı projelerini saklamak için):
# DATABASE_URL=
